# Switch between providers: "huggingface" or "runpod"
PROVIDER=huggingface

# ── HuggingFace ──────────────────────────────────────────
# HF Space to use (default: Lightricks/LTX-Video)
HF_SPACE=Lightricks/LTX-Video
# HuggingFace API token (needed for private spaces or to avoid rate limits)
HF_TOKEN=hf_...
# Gradio API endpoint name for image-to-video (check the Space's API docs)
HF_ENDPOINT=/image-to-video

# ── RunPod ───────────────────────────────────────────────
RUNPOD_API_KEY=your_runpod_api_key
# Your serverless endpoint ID (from RunPod dashboard)
RUNPOD_ENDPOINT_ID=your_endpoint_id
